        {
          "name": "TC_API_006 POST Add Product to Cart",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test (\"Status code is 201 or 200\", function () {\r",
                  "    pm.expect(pm.response.code).to.be.oneOf ([201, 200]);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response contains id\", function(){\r",
                  "    let jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData).to.have.property(\"id\");\r",
                  "\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response contains products array\", function(){\r",
                  "    let jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.products).to.be.an(\"array\");;\r",
                  "});\r",
                  "pm.test(\"Response time is less than 2000ms\", function(){\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});\r",
                  "\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
